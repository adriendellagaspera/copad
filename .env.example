# ============================================================================
#  Choose one or more storage backends. Only the ones you configure appear in
#  the app's backend picker (WebDAV is always available — creds entered at run).
# ============================================================================

# Default backend shown on load: pcloud | dropbox | webdav
VITE_STORAGE_BACKEND=dropbox

# OAuth popup landing page (shared by pCloud & Dropbox).
# VITE_REDIRECT_URI=http://localhost:5173/redirect.html

# Optional shared CORS proxy (Cloudflare Worker, see cloudflare-worker/).
# Required for WebDAV unless your server sends CORS headers; optional for pCloud.
# VITE_PROXY_URL=https://your-worker.workers.dev

# ---- Dropbox (recommended: cleanest browser-only flow) ----
# Create an app at https://www.dropbox.com/developers/apps (scoped access,
# permission files.content.read/write). Use the App key below and add your
# redirect URL (http://localhost:5173/redirect.html) under OAuth 2 → Redirect URIs.
VITE_DROPBOX_APP_KEY=
# VITE_DROPBOX_FILE_PATH=/collab-doc.ydoc

# ---- WebDAV / Nextcloud (self-hosted) ----
# URL is optional here (can be typed in the UI). Use a Nextcloud "app password".
# Needs VITE_PROXY_URL unless the server is CORS-enabled.
# VITE_WEBDAV_URL=https://cloud.exemple.fr/remote.php/dav/files/USER/Collab
# VITE_WEBDAV_FILE_NAME=collab-doc.ydoc

# ---- pCloud ----
# App at https://docs.pcloud.com → My applications. Add the redirect URL too.
VITE_PCLOUD_CLIENT_ID=
# VITE_PCLOUD_FILE_NAME=collab-doc.ydoc
# VITE_PCLOUD_FOLDER_ID=0

# ============================================================================
#  Realtime (y-webrtc) — same for every backend
# ============================================================================
VITE_ROOM=collab-files-demo
# Optional shared password → end-to-end encrypts the P2P channel.
# VITE_ROOM_PASSWORD=change-me
# Signaling server(s), comma-separated. For local dev run `npm run signaling`.
VITE_SIGNALING_URL=ws://localhost:4444
