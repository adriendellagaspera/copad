# ── Storage backends ─────────────────────────────────────────────────────────
# App keys below are OPTIONAL: users can also enter them at runtime via the
# in-app Settings (⚙) panel, where they're saved per-browser. Set a key here to
# manage it centrally — it then shows as "managed" and locked in Settings.

# Dropbox (OAuth 2 PKCE — no backend required)
# Create an app at https://www.dropbox.com/developers/apps
# Permissions needed: files.content.read, files.content.write
VITE_DROPBOX_APP_KEY=

# pCloud (OAuth token — content reads may need the proxy)
# Create an app at https://docs.pcloud.com → My applications
VITE_PCLOUD_CLIENT_ID=

# WebDAV / Nextcloud (Basic auth — requires the CORS proxy below)
# No key needed; credentials are entered at runtime in the UI.

# ── OAuth redirect URI ───────────────────────────────────────────────────────
# Must match the URI registered in each provider's developer console.
# Defaults to http://localhost:5173/redirect.html for local dev.
# VITE_REDIRECT_URI=http://localhost:5173/redirect.html

# ── (Optional) CORS proxy ────────────────────────────────────────────────────
# Required for WebDAV and pCloud content reads.
# Deploy cloudflare-worker/ and set ALLOWED_HOSTS there to prevent relay abuse.
# VITE_PROXY_URL=https://your-worker.workers.dev

# ── Collaboration transport ──────────────────────────────────────────────────
# Which real-time transport to use — chosen EXPLICITLY (default: webrtc):
#   webrtc    — peer-to-peer (default). Needs a signaling server (below) + STUN/TURN.
#   websocket — a central y-websocket hub relays the document. No WebRTC, so no
#               STUN/TURN and no NAT traversal — the reliable choice for mobile /
#               restrictive networks. The server is in the data path and sees
#               plaintext, so VITE_ROOM_PASSWORD (E2E) does NOT apply.
# VITE_COLLAB_TRANSPORT=webrtc

# WebRTC signaling server(s), comma-separated (used when transport=webrtc). Peers
# MUST share a reachable signaling server to discover each other. On a deployed
# (https) site this MUST be wss:// (browsers block ws:// as mixed content); the
# ws://localhost default only works in local dev. If unset on a deployed origin,
# real-time collaboration is disabled and the app shows a warning banner.
# VITE_SIGNALING_URL=ws://localhost:4444

# y-websocket hub URL (used when transport=websocket). Must be wss:// on a deployed
# origin. Deploy any upstream y-websocket server — see README "Deploying a
# collaboration server".
# VITE_WEBSOCKET_URL=ws://localhost:1234

# Default room name — the room you land in when the URL has no ?room= param
# (all peers sharing a room collaborate in real time). Defaults to copad-demo.
# VITE_DEFAULT_ROOM=copad-demo

# ── Room access & encryption (WebRTC transport only) ─────────────────────────
# The WebSocket hub relays plaintext; VITE_ROOM_AUTH has no effect there.
#
# VITE_ROOM_AUTH selects how peers are permitted to join a room:
#   public          — no restriction; anyone with the URL joins (default).
#   site-password   — one password for every room, set via VITE_ROOM_PASSWORD.
#                     Useful for closed deployments managed by an operator.
#   room-password   — each room creator types a per-room password; it is
#                     remembered in the browser and shared out-of-band.
#                     A wrong/missing password looks like an empty room.
#   secret-link     — a random key is generated and embedded in the URL #k=
#                     fragment. Anyone with the full link can join and decrypt.
#                     The key never reaches the signaling server (hash = client-only).
# VITE_ROOM_AUTH=public

# Deployment-managed password for site-password mode.
# Also accepted as a global fallback when VITE_ROOM_AUTH is not set (legacy).
# VITE_ROOM_PASSWORD=

# ── WebRTC NAT traversal (STUN / TURN) ───────────────────────────────────────
# Only relevant to the default WebRTC transport (not the WebSocket hub above).
# A public STUN server (below) is enough for most home/office networks. Mobile
# carriers and other restrictive networks use symmetric NAT / CGNAT, where STUN
# fails and a TURN relay is required for desktop↔mobile sessions to connect.
#
# Out of the box, when NO TURN is configured Copad falls back to a free PUBLIC
# relay (OpenRelay) so desktop↔mobile "just works" — but it's best-effort and
# rate-limited. For anything serious, set your own TURN below (or at runtime in
# the in-app Settings → Connection panel, which overrides these and the default).
#
# Comma-separated STUN URLs (defaults to Google's public STUN; set empty to disable).
# VITE_STUN_URL=stun:stun.l.google.com:19302
# TURN relay (comma-separated) + long-term credentials. Run e.g. coturn (see the
# turn/ folder) or use a hosted TURN provider.
# VITE_TURN_URL=turns:your-turn-server:5349
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=

# Which storage backend to connect by default (id: "dropbox", "pcloud", "webdav")
# VITE_STORAGE_BACKEND=dropbox
