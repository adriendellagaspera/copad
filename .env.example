# ── Storage backends ─────────────────────────────────────────────────────────
# App keys below are OPTIONAL: users can also enter them at runtime via the
# in-app Settings (⚙) panel, where they're saved per-browser. Set a key here to
# manage it centrally — it then shows as "managed" and locked in Settings.

# Dropbox (OAuth 2 PKCE — no backend required)
# Create an app at https://www.dropbox.com/developers/apps
# Permissions needed: files.content.read, files.content.write
VITE_DROPBOX_APP_KEY=

# pCloud (OAuth token — content reads may need the proxy)
# Create an app at https://docs.pcloud.com → My applications
VITE_PCLOUD_CLIENT_ID=

# WebDAV / Nextcloud (Basic auth — requires the CORS proxy below)
# No key needed; credentials are entered at runtime in the UI.

# ── OAuth redirect URI ───────────────────────────────────────────────────────
# Must match the URI registered in each provider's developer console.
# Defaults to http://localhost:5173/redirect.html for local dev.
# VITE_REDIRECT_URI=http://localhost:5173/redirect.html

# ── (Optional) CORS proxy ────────────────────────────────────────────────────
# Required for WebDAV and pCloud content reads.
# Deploy cloudflare-worker/ and set ALLOWED_HOSTS there to prevent relay abuse.
# VITE_PROXY_URL=https://your-worker.workers.dev

# ── Collaboration ────────────────────────────────────────────────────────────
# Comma-separated list of y-webrtc signaling servers. Peers MUST share a
# reachable signaling server to discover each other.
# On a deployed (https) site this MUST be wss:// — browsers block insecure ws://
# as mixed content. The ws://localhost default only works in local dev; if this
# is left unset on a deployed origin, real-time collaboration is disabled and
# the app shows a warning banner.
# Deploy signaling/ to Render or Fly.io — see README "Deploying the signaling server".
# VITE_SIGNALING_URL=ws://localhost:4444

# Room name (all peers sharing the same room collaborate in real time).
# VITE_ROOM=copad-demo

# Optional password — enables end-to-end encryption of P2P traffic.
# VITE_ROOM_PASSWORD=

# ── WebRTC NAT traversal (STUN / TURN) ───────────────────────────────────────
# A public STUN server (below) is enough for most home/office networks. Mobile
# carriers and other restrictive networks use symmetric NAT / CGNAT, where STUN
# fails and a TURN relay is required for desktop↔mobile sessions to connect.
# Comma-separated STUN URLs (defaults to Google's public STUN; set empty to disable).
# VITE_STUN_URL=stun:stun.l.google.com:19302
# TURN relay (comma-separated) + long-term credentials. Run e.g. coturn or use a
# hosted TURN provider.
# VITE_TURN_URL=turns:your-turn-server:5349
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=

# Which storage backend to connect by default (id: "dropbox", "pcloud", "webdav")
# VITE_STORAGE_BACKEND=dropbox
